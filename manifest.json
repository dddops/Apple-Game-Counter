{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "version": "0.2.2",
  "description": "__MSG_extDescription__",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.gamesaien.com/game/fruit_box_a/*",
        "https://www.gamesaien.com/game/fruit_box_a/"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js",
        "assets/apple-cuts/*",
        "assets/pattern.png",
        "assets/live-pattern.png"
      ],
      "matches": [
        "https://www.gamesaien.com/*"
      ]
    }
  ]
}
